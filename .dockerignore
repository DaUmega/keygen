.git
.gitignore
.github

# Generated artifacts — rebuilt inside the image during `docker build`.
# (scad/*.gen.scad is NOT excluded: it's a checked-in source file that
# openscad includes at render time, not a build-time artifact.)
build/*.json
!build/.gitignore

# Gitignored upstream; generated by docker/entrypoint.sh at container start
web/js/settings.js

**/__pycache__
**/*.pyc
.DS_Store
